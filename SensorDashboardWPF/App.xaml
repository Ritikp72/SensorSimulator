<Application x:Class="SensorDashboardWPF.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <!-- Color Resources -->
            <SolidColorBrush x:Key="BackgroundBrush" Color="#1E1E2E"/>
            <SolidColorBrush x:Key="CardBackgroundBrush" Color="#2D2D3D"/>
            <SolidColorBrush x:Key="HeaderBrush" Color="#00D4D4"/>
            <SolidColorBrush x:Key="BorderBrush" Color="#4A4A5A"/>
            <SolidColorBrush x:Key="TextBrush" Color="#E0E0E0"/>
            <SolidColorBrush x:Key="SubtextBrush" Color="#A0A0A0"/>
            <SolidColorBrush x:Key="GoodBrush" Color="#50C878"/>
            <SolidColorBrush x:Key="WarningBrush" Color="#FFD700"/>
            <SolidColorBrush x:Key="DangerBrush" Color="#FF5050"/>
            
            <!-- Button Style -->
            <Style x:Key="ModernButton" TargetType="Button">
                <Setter Property="Background" Value="#3D3D4D"/>
                <Setter Property="Foreground" Value="#E0E0E0"/>
                <Setter Property="BorderBrush" Value="#4A4A5A"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="15,8"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="5"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#4D4D5D"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
