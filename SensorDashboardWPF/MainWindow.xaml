<Window x:Class="SensorDashboardWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sensor Simulator Dashboard" 
        Height="700" 
        Width="1100"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterScreen">
    
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Border Grid.Row="0" 
                Background="{StaticResource CardBackgroundBrush}" 
                CornerRadius="10" 
                Padding="20" 
                Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="🌡️ SENSOR SIMULATOR DASHBOARD" 
                               FontSize="24" 
                               FontWeight="Bold" 
                               Foreground="{StaticResource HeaderBrush}"/>
                    <TextBlock x:Name="DateTimeText" 
                               Foreground="{StaticResource SubtextBrush}" 
                               FontSize="14"
                               Margin="0,5,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Uptime: " Foreground="{StaticResource SubtextBrush}" VerticalAlignment="Center"/>
                    <TextBlock x:Name="UptimeText" Foreground="{StaticResource TextBrush}" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- Sensor Cards Grid -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- Temperature Card -->
            <Border Grid.Row="0" Grid.Column="0" 
                    Background="{StaticResource CardBackgroundBrush}" 
                    CornerRadius="10" 
                    Padding="15" 
                    Margin="5">
                <StackPanel>
                    <TextBlock Text="🌡️ Temperature" 
                               FontSize="16" 
                               FontWeight="Bold" 
                               Foreground="{StaticResource HeaderBrush}"/>
                    <TextBlock x:Name="TempValue" 
                               FontSize="36" 
                               FontWeight="Bold" 
                               Margin="0,10,0,0"/>
                    <TextBlock Text="Current" Foreground="{StaticResource SubtextBrush}" FontSize="10"/>
                    
                    <Separator Margin="0,15"/>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Min:" Foreground="{StaticResource SubtextBrush}"/>
                        <TextBlock x:Name="TempMin" Grid.Row="0" Grid.Column="1" Foreground="{StaticResource WarningBrush}"/>
                        
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Max:" Foreground="{StaticResource SubtextBrush}"/>
                        <TextBlock x:Name="TempMax" Grid.Row="1" Grid.Column="1" Foreground="{StaticResource DangerBrush}"/>
                        
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Avg:" Foreground="{StaticResource SubtextBrush}"/>
                        <TextBlock x:Name="TempAvg" Grid.Row="2" Grid.Column="1" Foreground="{StaticResource GoodBrush}"/>
                    </Grid>
                    
                    <ProgressBar x:Name="TempProgress" 
                                 Height="15" 
                                 Margin="0,15,0,5"
                                 Background="#3D3D4D"/>
                </StackPanel>
            </Border>
            
            <!-- Pressure Card -->
            <Border Grid.Row="0" Grid.Column="1" 
                    Background="{StaticResource CardBackgroundBrush}" 
                    CornerRadius="10" 
                    Padding="15" 
                    Margin="5">
                <StackPanel>
                    <TextBlock Text="🌡️ Pressure" 
                               FontSize="16" 
                               FontWeight="Bold" 
                               Foreground="{StaticResource HeaderBrush}"/>
                    <TextBlock x:Name="PressureValue" 
                               FontSize="36" 
                               FontWeight="Bold" 
                               Margin="0,10,0,0"/>
                    <TextBlock Text="Current (hPa)" Foreground="{StaticResource SubtextBrush}" FontSize="10"/>
                    
                    <Separator Margin="0,15"/>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Min:" Foreground="{StaticResource SubtextBrush}"/>
                        <TextBlock x:Name="PressureMin" Grid.Row="0" Grid.Column="1" Foreground="{StaticResource WarningBrush}"/>
                        
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Max:" Foreground="{StaticResource SubtextBrush}"/>
                        <TextBlock x:Name="PressureMax" Grid.Row="1" Grid.Column="1" Foreground="{StaticResource DangerBrush}"/>
                        
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Avg:" Foreground="{StaticResource SubtextBrush}"/>
                        <TextBlock x:Name="PressureAvg" Grid.Row="2" Grid.Column="1" Foreground="{StaticResource GoodBrush}"/>
                    </Grid>
                    
                    <ProgressBar x:Name="PressureProgress" 
                                 Height="15" 
                                 Margin="0,15,0,5"
                                 Background="#3D3D4D"/>
                </StackPanel>
            </Border>
            
            <!-- Humidity Card -->
            <Border Grid.Row="0" Grid.Column="2" 
                    Background="{StaticResource CardBackgroundBrush}" 
                    CornerRadius="10" 
                    Padding="15" 
                    Margin="5">
                <StackPanel>
                    <TextBlock Text="💧 Humidity" 
                               FontSize="16" 
                               FontWeight="Bold" 
                               Foreground="{StaticResource HeaderBrush}"/>
                    <TextBlock x:Name="HumidityValue" 
                               FontSize="36" 
                               FontWeight="Bold" 
                               Margin="0,10,0,0"/>
                    <TextBlock Text="Current (%)" Foreground="{StaticResource SubtextBrush}" FontSize="10"/>
                    
                    <Separator Margin="0,15"/>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Min:" Foreground="{StaticResource SubtextBrush}"/>
                        <TextBlock x:Name="HumidityMin" Grid.Row="0" Grid.Column="1" Foreground="{StaticResource WarningBrush}"/>
                        
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Max:" Foreground="{StaticResource SubtextBrush}"/>
                        <TextBlock x:Name="HumidityMax" Grid.Row="1" Grid.Column="1" Foreground="{StaticResource DangerBrush}"/>
                        
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Avg:" Foreground="{StaticResource SubtextBrush}"/>
                        <TextBlock x:Name="HumidityAvg" Grid.Row="2" Grid.Column="1" Foreground="{StaticResource GoodBrush}"/>
                    </Grid>
                    
                    <ProgressBar x:Name="HumidityProgress" 
                                 Height="15" 
                                 Margin="0,15,0,5"
                                 Background="#3D3D4D"/>
                </StackPanel>
            </Border>
            
            <!-- Light Card -->
            <Border Grid.Row="1" Grid.Column="0" 
                    Background="{StaticResource CardBackgroundBrush}" 
                    CornerRadius="10" 
                    Padding="15" 
                    Margin="5">
                <StackPanel>
                    <TextBlock Text="💡 Light" 
                               FontSize="16" 
                               FontWeight="Bold" 
                               Foreground="{StaticResource WarningBrush}"/>
                    <TextBlock x:Name="LightValue" 
                               FontSize="36" 
                               FontWeight="Bold" 
                               Margin="0,10,0,0"/>
                    <TextBlock Text="Current (lux)" Foreground="{StaticResource SubtextBrush}" FontSize="10"/>
                    
                    <Separator Margin="0,15"/>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Min:" Foreground="{StaticResource SubtextBrush}"/>
                        <TextBlock x:Name="LightMin" Grid.Row="0" Grid.Column="1" Foreground="{StaticResource WarningBrush}"/>
                        
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Max:" Foreground="{StaticResource SubtextBrush}"/>
                        <TextBlock x:Name="LightMax" Grid.Row="1" Grid.Column="1" Foreground="{StaticResource DangerBrush}"/>
                        
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Avg:" Foreground="{StaticResource SubtextBrush}"/>
                        <TextBlock x:Name="LightAvg" Grid.Row="2" Grid.Column="1" Foreground="{StaticResource GoodBrush}"/>
                    </Grid>
                    
                    <ProgressBar x:Name="LightProgress" 
                                 Height="15" 
                                 Margin="0,15,0,5"
                                 Background="#3D3D4D"/>
                </StackPanel>
            </Border>
            
            <!-- CO2 Card -->
            <Border Grid.Row="1" Grid.Column="1" 
                    Background="{StaticResource CardBackgroundBrush}" 
                    CornerRadius="10" 
                    Padding="15" 
                    Margin="5">
                <StackPanel>
                    <TextBlock Text="🌬️ CO2" 
                               FontSize="16" 
                               FontWeight="Bold" 
                               Foreground="#C864FF"/>
                    <TextBlock x:Name="CO2Value" 
                               FontSize="36" 
                               FontWeight="Bold" 
                               Margin="0,10,0,0"/>
                    <TextBlock Text="Current (ppm)" Foreground="{StaticResource SubtextBrush}" FontSize="10"/>
                    
                    <Separator Margin="0,15"/>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Min:" Foreground="{StaticResource SubtextBrush}"/>
                        <TextBlock x:Name="CO2Min" Grid.Row="0" Grid.Column="1" Foreground="{StaticResource WarningBrush}"/>
                        
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Max:" Foreground="{StaticResource SubtextBrush}"/>
                        <TextBlock x:Name="CO2Max" Grid.Row="1" Grid.Column="1" Foreground="{StaticResource DangerBrush}"/>
                        
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Avg:" Foreground="{StaticResource SubtextBrush}"/>
                        <TextBlock x:Name="CO2Avg" Grid.Row="2" Grid.Column="1" Foreground="{StaticResource GoodBrush}"/>
                    </Grid>
                    
                    <ProgressBar x:Name="CO2Progress" 
                                 Height="15" 
                                 Margin="0,15,0,5"
                                 Background="#3D3D4D"/>
                </StackPanel>
            </Border>
            
            <!-- Noise Card -->
            <Border Grid.Row="1" Grid.Column="2" 
                    Background="{StaticResource CardBackgroundBrush}" 
                    CornerRadius="10" 
                    Padding="15" 
                    Margin="5">
                <StackPanel>
                    <TextBlock Text="🔊 Noise" 
                               FontSize="16" 
                               FontWeight="Bold" 
                               Foreground="#FF64C8"/>
                    <TextBlock x:Name="NoiseValue" 
                               FontSize="36" 
                               FontWeight="Bold" 
                               Margin="0,10,0,0"/>
                    <TextBlock Text="Current (dB)" Foreground="{StaticResource SubtextBrush}" FontSize="10"/>
                    
                    <Separator Margin="0,15"/>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Min:" Foreground="{StaticResource SubtextBrush}"/>
                        <TextBlock x:Name="NoiseMin" Grid.Row="0" Grid.Column="1" Foreground="{StaticResource WarningBrush}"/>
                        
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Max:" Foreground="{StaticResource SubtextBrush}"/>
                        <TextBlock x:Name="NoiseMax" Grid.Row="1" Grid.Column="1" Foreground="{StaticResource DangerBrush}"/>
                        
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Avg:" Foreground="{StaticResource SubtextBrush}"/>
                        <TextBlock x:Name="NoiseAvg" Grid.Row="2" Grid.Column="1" Foreground="{StaticResource GoodBrush}"/>
                    </Grid>
                    
                    <ProgressBar x:Name="NoiseProgress" 
                                 Height="15" 
                                 Margin="0,15,0,5"
                                 Background="#3D3D4D"/>
                </StackPanel>
            </Border>
        </Grid>
        
        <!-- Alerts Panel -->
        <Border Grid.Row="3" 
                Background="{StaticResource CardBackgroundBrush}" 
                CornerRadius="10" 
                Padding="15" 
                Margin="0,10,0,10"
                MaxHeight="120">
            <StackPanel>
                <TextBlock Text="⚠️ Alerts" 
                           FontSize="16" 
                           FontWeight="Bold" 
                           Foreground="{StaticResource WarningBrush}"
                           Margin="0,0,0,10"/>
                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="80">
                    <TextBlock x:Name="AlertsText" 
                               Foreground="{StaticResource TextBrush}"
                               TextWrapping="Wrap"/>
                </ScrollViewer>
            </StackPanel>
        </Border>
        
        <!-- Control Buttons -->
        <StackPanel Grid.Row="4" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Center"
                    Margin="0,10,0,0">
            <Button x:Name="StartButton" 
                    Content="▶ Start" 
                    Style="{StaticResource ModernButton}"
                    Click="StartButton_Click"
                    Margin="5"/>
            <Button x:Name="StopButton" 
                    Content="⏹ Stop" 
                    Style="{StaticResource ModernButton}"
                    Click="StopButton_Click"
                    IsEnabled="False"
                    Margin="5"/>
            <Button Content="📸 Screenshot" 
                    Style="{StaticResource ModernButton}"
                    Click="ScreenshotButton_Click"
                    Margin="5"/>
            <Button Content="💾 Save Data" 
                    Style="{StaticResource ModernButton}"
                    Click="SaveDataButton_Click"
                    Margin="5"/>
        </StackPanel>
    </Grid>
</Window>
